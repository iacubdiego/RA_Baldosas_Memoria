# MongoDB
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/baldosas_db

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Storage (Cloudflare R2 o Vercel Blob)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_BUCKET_NAME=baldosas-storage
NEXT_PUBLIC_STORAGE_URL=https://storage.example.com

# Worker (para compilación futura)
RAILWAY_WEBHOOK_URL=https://your-railway-app.up.railway.app/webhook/compile
